# ============================================================================
# ai-narrative — пример конфигурации. Скопируй в .env и впиши значения:
#   cp .env.example .env
# .env в .gitignore — ключи НЕ коммитятся.
# ============================================================================

# --- OpenRouter: боты 1-5, редактор, перевод (если подписка Claude выключена) ---
# Ключ с https://openrouter.ai/keys . ОБЯЗАТЕЛЕН (минимум для адалта).
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Модель структурных ботов (логлайн/синопсис/персонажи/структура/диалоги).
# Дёшево и держит сюжет — Haiku 4.5 ($1/$5 за Mtok).
# Качественнее (дороже): anthropic/claude-sonnet-4.6 ($3/$15).
CLAUDE_MODEL=anthropic/claude-haiku-4.5
STRUCTURAL_TEMPERATURE=0.7
STRUCTURAL_MAX_TOKENS=0            # 0 = без лимита (главы не обрезаются)

# --- Редактор (Бот 7): частые вызовы + ретраи → дешёвая модель ---
EDITOR_MODEL=anthropic/claude-haiku-4.5
EDITOR_MAX_TOKENS=4000

# --- Адалт (Бот 6): модель без цензуры (Claude/подписка её не пишет) ---
# Дефолт — x-ai/grok-4.3: сильный русский + explicit + быстрый (~15-20с).
# Проверено прогонами: grok-4.20 цензурит, RP-тюны (Magnum/Cydonia) слабый RU,
# deepseek-v3.2 дешевле но медленнее и без кавычек. См. docs/.
# Локальная uncensored-модель (vLLM/koboldcpp): задай ADULT_BASE_URL/ADULT_API_KEY.
ADULT_MODEL=x-ai/grok-4.3
# ADULT_BASE_URL=http://localhost:8000/v1
# ADULT_API_KEY=local
ADULT_TEMPERATURE=0.9
ADULT_MAX_TOKENS=0                 # 0 = без лимита (адалт-сцена длинная)

# --- Claude по подписке (опционально): боты 1-5 + редактор без оплаты токенов ---
# Использует логин Claude Code (Pro/Max), а не платный API. Адалт всё равно
# идёт через OpenRouter (grok). Включается тумблером в UI или здесь:
USE_CLAUDE_SUBSCRIPTION=1          # 1 = все НЕ-адалт боты через подписку (дефолт)
CLAUDE_SUB_MODEL=sonnet           # haiku | sonnet | opus
# Долгоживущий токен из `claude setup-token` ИЛИ авторизация через UI.
# Если уже залогинен в Claude Code (~/.claude) — токен не нужен.
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat-...
# ВНИМАНИЕ: ANTHROPIC_API_KEY перебьёт подписку платным API — не задавай его,
# если хочешь именно подписку.

# --- Цикл правок редактор↔бот ---
MAX_REVISIONS=4                    # макс. авто-ревизий главы (UI-цикл без лимита)

# --- Сервер / прокси ---
# Разрешённые origin фронта (CSRF-защита бэка). Дефолт — localhost:3030/3000.
CORS_ORIGINS=http://localhost:3030,http://127.0.0.1:3030,http://localhost:3000,http://127.0.0.1:3000
# Путь к SQLite-чекпоинту (стейт прогонов). В Docker → том /app/data.
# NARRATIVE_DB=narrative_state.db
# Куда Next проксирует /api (только фронт). Локально 127.0.0.1, в Docker backend.
# BACKEND_URL=http://127.0.0.1:8000
