# --- Структурные боты (1-5, 8): Claude через OpenRouter ---
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Дефолт — Haiku 4.5 ($1/$5): дёшево, держит сюжет/диалоги.
# Качественнее (дороже): anthropic/claude-sonnet-4.6 ($3/$15).
CLAUDE_MODEL=anthropic/claude-haiku-4.5
STRUCTURAL_TEMPERATURE=0.7
# 0 = без лимита: главы/диалоги не обрезаются на полуслове.
STRUCTURAL_MAX_TOKENS=0

# --- Редактор (Бот 7): самый частый вызов, берём дешёвую модель ---
EDITOR_MODEL=anthropic/claude-haiku-4.5
EDITOR_MAX_TOKENS=4000

# --- Бот 6 (адалт): модель без цензуры ---
# Дефолт — x-ai/grok-4.3: сильный русский + explicit + быстрый (~15с/сцена).
# Бесплатная альтернатива: google/gemma-4-31b-it:free (медленнее ~130с).
# Профильные NSFW-тюны (Magnum/Cydonia) на русском ломаются — см. docs/.
# Локальный сервер (vLLM/text-generation-webui/koboldcpp):
#   ADULT_BASE_URL=http://localhost:8000/v1
#   ADULT_API_KEY=local
ADULT_MODEL=x-ai/grok-4.3
# ADULT_BASE_URL=
# ADULT_API_KEY=
ADULT_TEMPERATURE=0.9
# 0 = без лимита: адалт-сцена «уровня C» длинная, cap режет кульминацию.
ADULT_MAX_TOKENS=0

# --- Цикл правок editor↔bot ---
MAX_REVISIONS=4
